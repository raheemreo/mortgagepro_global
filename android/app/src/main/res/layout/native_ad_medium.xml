<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/native_ad_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/native_ad_border"
    android:paddingTop="8dp"
    android:paddingEnd="8dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layoutDirection="locale"
        android:paddingStart="@dimen/ad_card_padding"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="@dimen/ad_card_padding">

        <!-- MediaView: height varies by device class via dimens.xml / values-sw*dp -->
        <com.google.android.gms.ads.nativead.MediaView
            android:id="@+id/ad_media"
            android:layout_width="match_parent"
            android:layout_height="@dimen/ad_media_height"
            android:layout_alignParentTop="true"
            android:layout_marginStart="-8dp"
            android:layout_marginEnd="-8dp" />

        <!-- AdChoices View overlay at top-right of MediaView -->
        <com.google.android.gms.ads.nativead.AdChoicesView
            android:id="@+id/ad_choices"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="8dp" />

        <!-- Ad / Sponsored badge — placed BELOW media, not overlaying it,
             to avoid clutter or overlap risk with AdChoices in the media corner -->
        <LinearLayout
            android:id="@+id/ad_badge_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/ad_media"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/ad_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ad"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/native_ad_badge_background"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp" />

            <TextView
                android:id="@+id/ad_advertiser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="12sp"
                android:textColor="@color/ad_text_secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/ad_headline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/ad_badge_row"
            android:layout_marginTop="6dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/ad_text_primary"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/ad_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/ad_headline"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:textColor="@color/ad_text_secondary"
            android:maxLines="2"
            android:ellipsize="end" />

        <ImageView
            android:id="@+id/ad_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_below="@id/ad_body"
            android:layout_marginTop="10dp"
            android:layout_alignParentStart="true" />

        <!-- CTA: 48dp height per Material minimum touch target -->
        <Button
            android:id="@+id/ad_cta"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/ad_button_height"
            android:layout_below="@id/ad_body"
            android:layout_marginTop="10dp"
            android:layout_alignParentEnd="true"
            android:minWidth="@dimen/ad_button_min_width"
            android:background="@drawable/native_ad_button_background"
            android:textColor="@color/ad_button_text"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:paddingHorizontal="16dp" />

    </RelativeLayout>
</com.google.android.gms.ads.nativead.NativeAdView>
